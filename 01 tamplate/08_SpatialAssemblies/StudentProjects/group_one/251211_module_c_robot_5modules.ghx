              <chunks count="1">
                <chunk name="Container">
                  <items count="4">
                    <item name="Description" type_name="gh_string" type_code="10">Get a plane from a point in space and a 3D rotation. The input has to be a list of 6 or 7 numbers.</item>
                    <item name="InstanceGuid" type_name="gh_guid" type_code="9">5f57712d-60ef-4027-a3e9-7ac8cbc90194</item>
                    <item name="Name" type_name="gh_string" type_code="10">Get plane</item>
